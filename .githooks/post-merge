#!/bin/sh

# Only apply when merging into main
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$CURRENT_BRANCH" != "main" ]; then
  exit 0
fi

# .gitignore.main acts as sentinel: only present when merging from starter's dev branch.
# Future projects that clone main won't have this file, so the hook exits early for them.
if [ ! -f ".gitignore.main" ]; then
  exit 0
fi

echo "Applying main branch filters..."

# Replace .gitignore with the main version (without frontend/ backend/)
cp .gitignore.main .gitignore

# Stage removals and updated .gitignore
git rm -r --cached docs/ > /dev/null 2>&1 || true
git rm --cached .gitignore.main > /dev/null 2>&1
git add .gitignore

# Remove from working tree
rm -rf docs/
rm -f .gitignore.main

# Amend the merge commit to exclude the filtered content
git commit --amend --no-edit > /dev/null 2>&1

echo "Done: docs/ removed, .gitignore.main applied as .gitignore"
