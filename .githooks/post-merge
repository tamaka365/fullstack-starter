#!/bin/sh

# Only apply when merging into main
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$CURRENT_BRANCH" != "main" ]; then
  exit 0
fi

# .gitignore.main acts as sentinel: only present when merging from starter's dev branch.
# Future projects that clone main won't have this file, so the hook exits early for them.
if [ ! -f ".gitignore.main" ]; then
  exit 0
fi

echo "Applying main branch filters..."

# 1. Replace .gitignore with the main version (without frontend/ backend/)
cp .gitignore.main .gitignore
git rm --cached .gitignore.main > /dev/null 2>&1
rm -f .gitignore.main
git add .gitignore

# 2. Replace CLAUDE.md with the template version
cp CLAUDE.main.md CLAUDE.md
git rm --cached CLAUDE.main.md > /dev/null 2>&1
rm -f CLAUDE.main.md
git add CLAUDE.md

# 3. Remove dev-only .claude/docs/, install template .claude/docs.main/ as .claude/docs/
git rm -r --cached .claude/docs/ > /dev/null 2>&1 || true
rm -rf .claude/docs/
if [ -d ".claude/docs.main" ]; then
  cp -r .claude/docs.main .claude/docs
  git rm -r --cached .claude/docs.main > /dev/null 2>&1
  rm -rf .claude/docs.main
  git add .claude/docs/
fi

git commit -m "chore: apply main branch filters"

echo "Done"
