#!/bin/sh

echo "[pre-commit] fired"

[ -f ".git/MERGE_HEAD" ] && echo "[pre-commit] MERGE_HEAD exists" || { echo "[pre-commit] no MERGE_HEAD, exit"; exit 0; }

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
echo "[pre-commit] branch: $CURRENT_BRANCH"
[ "$CURRENT_BRANCH" = "main" ] || { echo "[pre-commit] not main, exit"; exit 0; }

MERGE_HEAD=$(cat .git/MERGE_HEAD)
echo "[pre-commit] MERGE_HEAD=$MERGE_HEAD"
git cat-file -e "$MERGE_HEAD:.gitignore.main" 2>/dev/null && echo "[pre-commit] sentinel found" || { echo "[pre-commit] no sentinel, exit"; exit 0; }

echo "[pre-commit] Applying filters..."
