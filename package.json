{
  "name": "fullstack-starter",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "new": "node scripts/new.mjs",
    "remove": "node scripts/remove.mjs",
    "rename": "node scripts/rename.mjs",
    "templatize": "node scripts/templatize.mjs",
    "contribute": "node scripts/contribute.mjs",
    "dev": "node scripts/run.mjs dev",
    "build": "node scripts/run.mjs build",
    "start": "node scripts/run.mjs start",
    "typecheck": "pnpm --recursive run typecheck",
    "prepare": "git config core.hooksPath .githooks && git config branch.main.mergeoptions --no-ff && git config merge.use-theirs.name 'Always accept theirs' && git config merge.use-theirs.driver 'cp %B %A'"
  },
  "devDependencies": {
    "@inquirer/prompts": "^7.5.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
